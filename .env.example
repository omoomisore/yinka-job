# ============================================================
# Yinka Job Bot - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# SerpAPI - Job Search (https://serpapi.com - free tier: 100 searches/month)
SERPAPI_KEY=your_serpapi_key_here

# OpenAI - Cover Letters & Job Scoring (https://platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here

# Email Notifications (Gmail App Password)
# To create an App Password: Google Account > Security > 2-Step Verification > App Passwords
SMTP_EMAIL=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
NOTIFICATION_EMAIL=olaomi@gmail.com
